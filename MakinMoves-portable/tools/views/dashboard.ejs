<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MakinMoves Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; padding: 2rem; }
    h1 { font-size: 2rem; margin-bottom: 0.5rem; color: #38bdf8; }
    .subtitle { color: #94a3b8; margin-bottom: 2rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .card { background: #1e293b; border-radius: 12px; padding: 1.5rem; border: 1px solid #334155; }
    .card h3 { color: #94a3b8; font-size: 0.875rem; text-transform: uppercase; margin-bottom: 0.5rem; }
    .card .value { font-size: 2rem; font-weight: bold; color: #22c55e; }
    .card .value.warn { color: #f59e0b; }
    .progress-bar { background: #334155; border-radius: 8px; height: 24px; overflow: hidden; margin-top: 1rem; }
    .progress-fill { background: linear-gradient(90deg, #22c55e, #38bdf8); height: 100%; border-radius: 8px; transition: width 0.5s; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid #334155; }
    th { color: #94a3b8; font-size: 0.875rem; }
    .stream-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
    .stream-digital { background: #7c3aed33; color: #a78bfa; }
    .stream-saas { background: #2563eb33; color: #60a5fa; }
    .stream-content { background: #059669; color: #6ee7b7; }
    .stream-trading { background: #d9770633; color: #fbbf24; }
  </style>
</head>
<body>
  <h1>MakinMoves</h1>
  <p class="subtitle">Passive Income Recovery Dashboard</p>

  <div class="grid">
    <div class="card">
      <h3>Total Revenue</h3>
      <div class="value">$<%= totalRevenue.toFixed(2) %></div>
    </div>
    <div class="card">
      <h3>Recovery Target</h3>
      <div class="value warn">$<%= recovery.target_amount || '0.00' %></div>
    </div>
    <div class="card">
      <h3>Recovered</h3>
      <div class="value">$<%= recovery.recovered_amount || '0.00' %></div>
      <% const pct = recovery.target_amount ? ((recovery.recovered_amount / recovery.target_amount) * 100).toFixed(1) : 0; %>
      <div class="progress-bar">
        <div class="progress-fill" style="width: <%= Math.min(pct, 100) %>%"><%= pct %>%</div>
      </div>
    </div>
  </div>

  <div class="grid">
    <div class="card" style="grid-column: span 2;">
      <h3>Revenue by Stream</h3>
      <table>
        <thead><tr><th>Stream</th><th>Entries</th><th>Total</th></tr></thead>
        <tbody>
          <% revenue.forEach(r => { %>
          <tr>
            <td><span class="stream-badge stream-<%= r.stream %>"><%= r.stream %></span></td>
            <td><%= r.entries %></td>
            <td>$<%= parseFloat(r.total).toFixed(2) %></td>
          </tr>
          <% }); %>
          <% if (revenue.length === 0) { %>
          <tr><td colspan="3" style="color: #64748b;">No revenue recorded yet. Time to start building!</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h3>Recent Sales</h3>
      <table>
        <thead><tr><th>Product</th><th>Net</th></tr></thead>
        <tbody>
          <% recentSales.forEach(s => { %>
          <tr>
            <td><%= s.name %></td>
            <td>$<%= parseFloat(s.net_amount || s.amount).toFixed(2) %></td>
          </tr>
          <% }); %>
          <% if (recentSales.length === 0) { %>
          <tr><td colspan="2" style="color: #64748b;">No sales yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
